# Discord Bot Token
DISCORD_TOKEN=your_bot_token_here

# スラッシュコマンドを即時反映させるギルド (サーバー) ID
# Discord でサーバー名を右クリック →「IDをコピー」で取得 (開発者モード必須)
# 設定しない場合はグローバル同期になり反映まで最大1時間かかる
DISCORD_GUILD_ID=your_guild_id_here

# Minecraft サーバー設定
MC_SERVER_DIR=/path/to/minecraft-server
MC_SCREEN_NAME=create
MC_START_SCRIPT=run.sh

# RCON 設定 (server.properties の設定と合わせる)
MC_RCON_HOST=localhost
MC_RCON_PORT=25575
MC_RCON_PASSWORD=your_rcon_password
